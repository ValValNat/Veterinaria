<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF9C4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asignar Cita"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#4E342E"
                android:layout_marginBottom="30dp"/>

            <!-- SPINNER MASCOTA -->
            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Paciente (mascota)"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerPaciente"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:layout_marginBottom="16dp"/>

            <!-- CLIENTE (SOLO LECTURA) -->
            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Cliente (dueño)"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCliente"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Se rellena automáticamente"
                android:focusable="false"
                android:clickable="false"
                android:background="#FFECB3"
                android:textColor="#4E342E"
                android:textColorHint="#BCAAA4"
                android:padding="10dp"
                android:layout_marginBottom="16dp"/>

            <!-- FECHA -->
            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etFecha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Selecciona una fecha"
                android:focusable="false"
                android:clickable="false"
                android:background="#FFECB3"
                android:textColor="#4E342E"
                android:textColorHint="#BCAAA4"
                android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSeleccionarFecha"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Seleccionar fecha"
                android:textColor="@android:color/white"
                android:backgroundTint="#FBC02D"
                android:layout_marginBottom="16dp"/>

            <!-- SPINNER HORA -->
            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Hora"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerHora"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:layout_marginBottom="16dp"/>

            <!-- MOTIVO -->
            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Motivo"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etMotivo"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Motivo de la cita"
                android:background="#FFECB3"
                android:textColor="#4E342E"
                android:textColorHint="#BCAAA4"
                android:padding="10dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnGuardarCita"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Guardar cita"
                android:textColor="@android:color/white"
                android:backgroundTint="#FBC02D"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>